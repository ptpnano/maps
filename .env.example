# ============================
# MapBoost Neon — Environment
# ============================
# Copy file này thành .env và điền giá trị thực

# PostgreSQL connection string (Neon, Supabase, Railway, v.v.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth v5 — bắt buộc phải set
# Tạo secret ngẫu nhiên: openssl rand -base64 32
AUTH_SECRET="your-random-secret-key-here"

# URL gốc của app (localhost khi dev)
NEXTAUTH_URL="http://localhost:3000"

# Secret cho cron endpoints (đặt header x-cron-secret khi gọi)
CRON_SECRET="your-cron-secret-here"
